# Copy this file to .env and fill in your real values.
# NEVER commit .env — only commit this .env.example file.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mapetite"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET="replace-with-64-random-hex-chars"
REFRESH_TOKEN_SECRET="replace-with-a-different-64-random-hex-chars"

# Gmail app password (not your real password)
# Enable at: myaccount.google.com > Security > App passwords
EMAIL_USER="you@gmail.com"
EMAIL_PASS="xxxx xxxx xxxx xxxx"

# Your live frontend URL for CORS
FRONTEND_URL="https://yourdomain.com"

NODE_ENV="production"
